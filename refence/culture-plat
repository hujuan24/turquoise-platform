<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>藏家论坛 - 松石雅集</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700;900&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --turquoise-dark: #0d5c5c;
      --turquoise-main: #1a7a7a;
      --turquoise-light: #2d9a9a;
      --turquoise-bright: #40e0d0;
      --gold: #c9a227;
      --gold-light: #e8d5a3;
      --warm-bg: #e8e4dc;
      --warm-bg-light: #f0ece4;
      --card-bg: rgba(255, 255, 255, 0.75);
      --text-dark: #2c2c2c;
      --text-muted: #5a5a5a;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Noto Serif SC', 'STSong', '宋体', 'Times New Roman', serif;
      background: var(--warm-bg);
      color: var(--text-dark);
      overflow-x: hidden;
      position: relative;
      min-height: 100vh;
    }

    /* 背景铁线纹理 */
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: 
        repeating-linear-gradient(45deg, transparent, transparent 60px, rgba(26, 122, 122, 0.015) 60px, rgba(26, 122, 122, 0.015) 62px),
        repeating-linear-gradient(-45deg, transparent, transparent 80px, rgba(26, 122, 122, 0.012) 80px, rgba(26, 122, 122, 0.012) 82px);
      pointer-events: none;
      z-index: 0;
    }

    /* 导航栏 */
    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      padding: 0 60px;
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: all 0.5s ease;
      background: rgba(232, 228, 220, 0.95);
      backdrop-filter: blur(20px);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.08);
    }

    .logo {
      font-size: 28px;
      font-weight: 700;
      color: var(--turquoise-dark);
      letter-spacing: 4px;
      text-shadow: 0 0 20px rgba(26, 122, 122, 0.15);
      cursor: pointer;
    }

    .nav-links {
      display: flex;
      gap: 40px;
      list-style: none;
    }

    .nav-links a {
      color: var(--text-dark);
      text-decoration: none;
      font-size: 15px;
      letter-spacing: 2px;
      position: relative;
      padding: 8px 0;
      transition: color 0.3s ease;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--turquoise-bright), var(--gold));
      transition: width 0.3s ease;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: var(--turquoise-main);
    }

    .nav-links a:hover::after,
    .nav-links a.active::after {
      width: 100%;
    }

    .nav-links a.secondary {
      color: var(--text-muted);
      font-size: 14px;
    }

    .nav-links a.secondary:hover {
      color: var(--turquoise-main);
    }

    .nav-icons {
      display: flex;
      gap: 25px;
      align-items: center;
    }

    .nav-icons a {
      color: var(--text-dark);
      font-size: 18px;
      transition: all 0.3s ease;
      position: relative;
    }

    .nav-icons a:hover {
      color: var(--gold);
      transform: scale(1.1);
    }

    .nav-icons a .badge {
      position: absolute;
      top: -8px;
      right: -8px;
      width: 18px;
      height: 18px;
      background: var(--turquoise-bright);
      border-radius: 50%;
      font-size: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: bold;
    }

    /* 页面标题区 */
    .page-header {
      padding: 160px 60px 60px;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    .page-title {
      font-size: 56px;
      font-weight: 900;
      letter-spacing: 16px;
      margin-bottom: 20px;
      background: linear-gradient(135deg, var(--turquoise-dark) 0%, var(--turquoise-main) 50%, var(--gold) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-family: 'Noto Serif SC', 'STSong', '宋体', 'Times New Roman', serif;
    }

    .page-subtitle {
      font-size: 18px;
      color: var(--text-muted);
      letter-spacing: 6px;
      font-weight: 400;
    }

    /* 标签栏 + 发帖入口 */
    .tag-bar {
      max-width: 1400px;
      margin: 0 auto 40px;
      padding: 0 60px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .tag-list {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
    }

    .tag-item {
      padding: 10px 24px;
      background: transparent;
      border: 1px solid rgba(201, 162, 39, 0.3);
      color: var(--text-muted);
      font-family: inherit;
      font-size: 14px;
      letter-spacing: 1px;
      cursor: pointer;
      border-radius: 25px;
      transition: all 0.4s ease;
      position: relative;
      overflow: hidden;
    }

    .tag-item::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(201, 162, 39, 0.1), rgba(64, 224, 208, 0.08));
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .tag-item:hover {
      border-color: var(--gold);
      color: var(--gold);
      transform: translateY(-2px);
    }

    .tag-item.active {
      border-color: var(--gold);
      color: var(--gold);
      background: rgba(201, 162, 39, 0.08);
    }

    .tag-item.active::before {
      opacity: 1;
    }

    .tag-item span {
      position: relative;
      z-index: 1;
    }

    .new-post-btn {
      padding: 14px 32px;
      background: linear-gradient(135deg, var(--turquoise-main), var(--turquoise-dark));
      border: none;
      color: #fff;
      font-family: inherit;
      font-size: 15px;
      letter-spacing: 2px;
      cursor: pointer;
      border-radius: 30px;
      transition: all 0.4s ease;
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 6px 20px rgba(26, 122, 122, 0.3);
    }

    .new-post-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(26, 122, 122, 0.4);
    }

    .new-post-btn i {
      font-size: 16px;
    }

    /* 主内容区 */
    .main-content {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 60px 80px;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 40px;
      position: relative;
      z-index: 1;
    }

    /* 帖子列表 */
    .post-list {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .post-card {
      background: var(--card-bg);
      border-radius: 12px;
      padding: 24px 28px;
      cursor: pointer;
      transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
      border: 1px solid transparent;
      position: relative;
    }

    .post-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      border-radius: 12px;
      border: 1px solid transparent;
      transition: all 0.5s ease;
      pointer-events: none;
    }

    .post-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
    }

    .post-card:hover::before {
      border-color: rgba(201, 162, 39, 0.2);
    }

    /* 置顶帖 */
    .post-card.pinned {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.85));
      border-left: 3px solid var(--gold);
    }

    .post-card.pinned::after {
      content: '置顶';
      position: absolute;
      top: 12px;
      right: 12px;
      padding: 4px 10px;
      background: linear-gradient(135deg, var(--gold), #d4af37);
      color: #fff;
      font-size: 11px;
      letter-spacing: 1px;
      border-radius: 4px;
      font-weight: 500;
    }

    .post-header {
      display: flex;
      align-items: flex-start;
      gap: 15px;
      margin-bottom: 12px;
    }

    .post-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--turquoise-dark);
      letter-spacing: 1px;
      line-height: 1.5;
      flex: 1;
      transition: color 0.3s ease;
    }

    .post-card:hover .post-title {
      color: var(--turquoise-main);
    }

    /* 精华徽章 */
    .essence-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      background: linear-gradient(135deg, var(--turquoise-main), var(--turquoise-dark));
      color: #fff;
      font-size: 11px;
      font-weight: bold;
      border-radius: 4px;
      margin-left: 8px;
      flex-shrink: 0;
    }

    /* 悬赏标签 */
    .reward-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      color: #fff;
      font-size: 12px;
      letter-spacing: 1px;
      border-radius: 4px;
      margin-left: 8px;
      flex-shrink: 0;
    }

    .reward-badge i {
      font-size: 11px;
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .post-author {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .author-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid rgba(201, 162, 39, 0.2);
    }

    .author-name {
      font-size: 14px;
      color: var(--text-dark);
      letter-spacing: 1px;
    }

    .post-tag {
      padding: 4px 12px;
      background: rgba(26, 122, 122, 0.08);
      color: var(--turquoise-main);
      font-size: 12px;
      letter-spacing: 1px;
      border-radius: 12px;
    }

    .post-stats {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-left: auto;
    }

    .stat-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--text-muted);
      letter-spacing: 1px;
    }

    .stat-item i {
      font-size: 14px;
      color: var(--gold);
    }

    .post-time {
      font-size: 13px;
      color: var(--text-muted);
      letter-spacing: 1px;
    }

    /* 侧边栏 */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 30px;
    }

    .sidebar-card {
      background: var(--card-bg);
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
      border: 1px solid transparent;
      transition: all 0.4s ease;
    }

    .sidebar-card:hover {
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
      border-color: rgba(201, 162, 39, 0.15);
    }

    .sidebar-title {
      font-size: 16px;
      color: var(--turquoise-dark);
      letter-spacing: 3px;
      margin-bottom: 20px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .sidebar-title i {
      color: var(--gold);
      font-size: 18px;
    }

    /* 平台鉴定师 */
    .appraiser-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .appraiser-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px;
      border-radius: 8px;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .appraiser-item:hover {
      background: rgba(201, 162, 39, 0.06);
    }

    .appraiser-avatar {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid rgba(201, 162, 39, 0.3);
    }

    .appraiser-info {
      flex: 1;
    }

    .appraiser-name {
      font-size: 15px;
      color: var(--text-dark);
      letter-spacing: 1px;
      margin-bottom: 4px;
    }

    .appraiser-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px;
      background: linear-gradient(135deg, var(--gold), #d4af37);
      color: #fff;
      font-size: 11px;
      letter-spacing: 1px;
      border-radius: 10px;
    }

    .appraiser-badge i {
      font-size: 10px;
    }

    /* 本周热议 */
    .hot-topics {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .hot-topic-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 10px 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .hot-topic-item:last-child {
      border-bottom: none;
    }

    .hot-topic-item:hover {
      padding-left: 5px;
    }

    .hot-rank {
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      color: #fff;
      font-size: 12px;
      font-weight: bold;
      border-radius: 4px;
      flex-shrink: 0;
    }

    .hot-rank.second {
      background: linear-gradient(135deg, var(--gold), #d4af37);
    }

    .hot-rank.third {
      background: linear-gradient(135deg, var(--turquoise-main), var(--turquoise-dark));
    }

    .hot-topic-title {
      flex: 1;
      font-size: 14px;
      color: var(--text-dark);
      line-height: 1.5;
      letter-spacing: 1px;
      transition: color 0.3s ease;
    }

    .hot-topic-item:hover .hot-topic-title {
      color: var(--turquoise-main);
    }

    .hot-icon {
      color: #ff6b35;
      font-size: 14px;
      flex-shrink: 0;
    }

    /* 论坛公告 */
    .notice-list {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .notice-item {
      padding: 12px 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.6;
      letter-spacing: 1px;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .notice-item:last-child {
      border-bottom: none;
    }

    .notice-item:hover {
      color: var(--turquoise-main);
      padding-left: 5px;
    }

    .notice-date {
      font-size: 12px;
      color: var(--gold);
      margin-top: 4px;
      letter-spacing: 1px;
    }

    /* 分页器 */
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      padding: 40px 0 80px;
      position: relative;
      z-index: 1;
    }

    .page-btn {
      min-width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--card-bg);
      border: 1px solid rgba(201, 162, 39, 0.2);
      border-radius: 8px;
      color: var(--text-dark);
      font-family: inherit;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s ease;
      letter-spacing: 1px;
    }

    .page-btn:hover {
      border-color: var(--gold);
      color: var(--gold);
      transform: translateY(-2px);
    }

    .page-btn.active {
      background: linear-gradient(135deg, var(--turquoise-main), var(--turquoise-dark));
      border-color: transparent;
      color: #fff;
    }

    .page-btn.prev,
    .page-btn.next {
      padding: 0 20px;
    }

    .page-btn.prev i,
    .page-btn.next i {
      font-size: 12px;
    }

    .page-dots {
      color: var(--text-muted);
      padding: 0 10px;
    }

    /* 页脚 */
    .footer {
      background: linear-gradient(180deg, #ddd8d0 0%, #d0cbc3 100%);
      position: relative;
      z-index: 1;
    }

    .footer::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201, 162, 39, 0.25), transparent);
    }

    .footer-content {
      max-width: 1400px;
      margin: 0 auto;
      padding: 80px 60px 40px;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 60px;
    }

    .footer-brand {
      display: flex;
      flex-direction: column;
    }

    .footer-logo {
      font-size: 32px;
      font-weight: 700;
      color: var(--turquoise-dark);
      letter-spacing: 6px;
      margin-bottom: 25px;
    }

    .footer-desc {
      font-size: 14px;
      line-height: 1.8;
      color: var(--text-muted);
      margin-bottom: 30px;
      max-width: 350px;
    }

    .footer-social {
      display: flex;
      gap: 15px;
    }

    .footer-social a {
      width: 45px;
      height: 45px;
      border: 1px solid rgba(64, 224, 208, 0.25);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      font-size: 18px;
      transition: all 0.3s ease;
    }

    .footer-social a:hover {
      border-color: var(--turquoise-bright);
      color: var(--turquoise-main);
      transform: translateY(-3px);
      box-shadow: 0 5px 20px rgba(64, 224, 208, 0.12);
    }

    .footer-column h4 {
      font-size: 16px;
      color: var(--turquoise-dark);
      letter-spacing: 3px;
      margin-bottom: 25px;
      font-weight: 400;
    }

    .footer-links {
      list-style: none;
    }

    .footer-links li {
      margin-bottom: 15px;
    }

    .footer-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 14px;
      letter-spacing: 1px;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .footer-links a::before {
      content: '';
      width: 0;
      height: 1px;
      background: var(--turquoise-main);
      transition: width 0.3s ease;
    }

    .footer-links a:hover {
      color: var(--turquoise-main);
      padding-left: 5px;
    }

    .footer-links a:hover::before {
      width: 10px;
    }

    .footer-contact p {
      font-size: 14px;
      color: var(--text-muted);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .footer-contact i {
      color: var(--turquoise-main);
      width: 20px;
    }

    .footer-bottom {
      border-top: 1px solid rgba(0, 0, 0, 0.05);
      padding: 30px 60px;
      text-align: center;
    }

    .footer-slogan {
      font-size: 16px;
      color: var(--turquoise-dark);
      letter-spacing: 4px;
      margin-bottom: 15px;
      font-weight: 300;
    }

    .footer-copy {
      font-size: 12px;
      color: var(--text-muted);
      letter-spacing: 2px;
    }

    /* 回到顶部按钮 */
    .back-to-top {
      position: fixed;
      bottom: 40px;
      right: 40px;
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, var(--turquoise-main), var(--turquoise-dark));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      visibility: hidden;
      transition: all 0.4s ease;
      box-shadow: 0 8px 25px rgba(26, 122, 122, 0.3);
      z-index: 999;
      border: 2px solid rgba(201, 162, 39, 0.3);
    }

    .back-to-top.visible {
      opacity: 1;
      visibility: visible;
    }

    .back-to-top:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 35px rgba(26, 122, 122, 0.4);
      border-color: var(--gold);
    }

    .back-to-top i {
      font-size: 20px;
      color: #fff;
    }

    /* 响应式 */
    @media (max-width: 1200px) {
      .main-content {
        grid-template-columns: 1fr;
      }
      .sidebar {
        display: none;
      }
      .footer-content {
        grid-template-columns: 1fr 1fr;
        gap: 40px;
      }
    }

    @media (max-width: 768px) {
      .navbar {
        padding: 0 20px;
      }
      .nav-links {
        display: none;
      }
      .page-header {
        padding: 140px 20px 40px;
      }
      .page-title {
        font-size: 36px;
        letter-spacing: 8px;
      }
      .page-subtitle {
        font-size: 14px;
        letter-spacing: 3px;
      }
      .tag-bar {
        padding: 0 20px;
        flex-direction: column;
        gap: 20px;
        align-items: stretch;
      }
      .tag-list {
        justify-content: center;
